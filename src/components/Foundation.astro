---
// Sección 2: Identidad y Escala — dark luxury, contadores en dorado
const metricas = [
  { valor: 30,   sufijo: '+', etiqueta: 'Años de Tradición',      descripcion: 'De liderazgo ganadero ininterrumpido' },
  { valor: 5000, sufijo: '+', etiqueta: 'Hectáreas bajo Gestión', descripcion: 'De praderas y bosques productivos' },
  { valor: 120,  sufijo: '+', etiqueta: 'Empleos Directos',       descripcion: 'Familias colombianas en formalidad laboral' },
];
---

<section
  id="fundacion"
  class="relative py-16 sm:py-20 md:py-28 px-5 sm:px-6 overflow-hidden"
  style="background-color: #141414; border-top: 1px solid rgba(139,26,26,0.35);"
  aria-labelledby="fundacion-titulo"
>
  <!-- Resplandor dorado tenue en esquina — eco del logo -->
  <div
    class="absolute pointer-events-none"
    style="bottom: -100px; left: -100px; width: 400px; height: 400px;
           background: radial-gradient(circle, rgba(201,150,58,0.08) 0%, transparent 65%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-6xl mx-auto">

    <!-- Separador editorial con número de sección -->
    <div class="flex items-center gap-6 mb-20" aria-hidden="true">
      <div class="flex-1 h-px" style="background: rgba(240,235,225,0.08);"></div>
      <span class="font-sans text-[9px] tracking-[0.6em] uppercase" style="color: rgba(201,150,58,0.4);">01</span>
      <div class="flex-1 h-px" style="background: rgba(240,235,225,0.08);"></div>
    </div>

    <!-- Encabezado editorial -->
    <div class="grid md:grid-cols-2 gap-10 md:gap-16 items-start mb-16 md:mb-24">
      <div data-animate="fade-up">
        <p class="font-sans text-xs tracking-[0.35em] uppercase font-semibold mb-5" style="color: #C9963A;">
          Identidad y Escala
        </p>
        <h2 id="fundacion-titulo" class="font-serif text-4xl md:text-5xl leading-[1.15]" style="color: #F0EBE1;">
          Un motor dentro de la economía más grande del campo colombiano
        </h2>
      </div>
      <div data-animate="fade-up" style="transition-delay: 0.2s;">
        <p class="font-body text-lg leading-relaxed mb-6" style="color: rgba(240,235,225,0.5);">
          Colombia posee más de
          <strong style="color: rgba(240,235,225,0.85); font-weight: 600;">29,5 millones de cabezas de ganado</strong>
          y la cadena cárnica genera más de
          <strong style="color: rgba(240,235,225,0.85); font-weight: 600;">un millón de empleos</strong>
          directos e indirectos. RB Ganadería es un motor activo de esta economía nacional.
        </p>
        <p class="font-body text-lg leading-relaxed" style="color: rgba(240,235,225,0.5);">
          Nuestra operación integra genética de precisión, manejo silvopastoril y gestión territorial responsable,
          consolidando un modelo replicable de producción bovina sostenible.
        </p>
      </div>
    </div>

    <!-- Contadores en dorado sobre negro -->
    <div
      class="grid grid-cols-1 md:grid-cols-3"
      style="border: 1px solid rgba(139,26,26,0.2);"
      role="list"
      aria-label="Métricas de la empresa"
    >
      {metricas.map((m, i) => (
        <div
          class={`metric-card relative px-6 py-12 sm:px-10 sm:py-16 text-center group`}
          role="listitem"
          data-animate="fade-up"
        >
          <!-- Glow dorado en hover -->
          <div
            class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
            style="background: radial-gradient(ellipse 80% 70% at 50% 100%, rgba(201,150,58,0.07) 0%, transparent 70%);"
            aria-hidden="true"
          ></div>

          <!-- Número contador en Playfair dorado -->
          <p
            class="relative font-serif tabular-nums tracking-tight"
            style="font-size: clamp(4rem, 8vw, 6rem); color: #C9963A; margin-bottom: 1.25rem; line-height: 1;"
            data-counter
            data-target={m.valor}
            data-suffix={m.sufijo}
            aria-label={`${m.valor}${m.sufijo} ${m.etiqueta}`}
          >
            0{m.sufijo}
          </p>

          <!-- Línea carmesí bajo el número -->
          <div
            class="mx-auto mb-5 transition-all duration-500 group-hover:w-16"
            style="width: 32px; height: 1px; background-color: rgba(139,26,26,0.6);"
            aria-hidden="true"
          ></div>

          <p class="font-sans font-medium text-xs uppercase tracking-[0.22em] mb-2" style="color: rgba(240,235,225,0.55);">
            {m.etiqueta}
          </p>
          <p class="font-body text-sm leading-snug" style="color: rgba(240,235,225,0.3);">
            {m.descripcion}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Bordes del grid de métricas — mobile: horizontal, desktop: vertical */
  .metric-card {
    border-bottom: 1px solid rgba(139,26,26,0.2);
  }
  .metric-card:last-child {
    border-bottom: none;
  }
  @media (min-width: 768px) {
    .metric-card {
      border-bottom: none;
      border-right: 1px solid rgba(139,26,26,0.2);
    }
    .metric-card:last-child {
      border-right: none;
    }
  }
</style>

<script>
  const observerOptions: IntersectionObserverInit = { threshold: 0.15 };

  const fadeObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        (entry.target as HTMLElement).style.opacity = '1';
        (entry.target as HTMLElement).style.transform = 'translateY(0)';
        fadeObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('[data-animate="fade-up"]').forEach((el) => {
    const htmlEl = el as HTMLElement;
    htmlEl.style.opacity = '0';
    htmlEl.style.transform = 'translateY(28px)';
    htmlEl.style.transition = 'opacity 0.8s ease-out, transform 0.8s ease-out';
    fadeObserver.observe(htmlEl);
  });

  const counterObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      const target = parseInt(el.dataset.target ?? '0', 10);
      const suffix = el.dataset.suffix ?? '';
      const duration = 2000;
      const start = performance.now();

      const step = (now: number) => {
        const elapsed = now - start;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        el.textContent = Math.floor(eased * target) + suffix;
        if (progress < 1) requestAnimationFrame(step);
      };

      requestAnimationFrame(step);
      counterObserver.unobserve(el);
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('[data-counter]').forEach((el) => counterObserver.observe(el));
</script>
