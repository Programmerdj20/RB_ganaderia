---
// Sección 4: Impacto Territorial — mapa de Colombia + narrativa, dark luxury
const pilares = [
  {
    titulo:  'Una Potencia Ganadera Continental',
    cuerpo:  'Colombia cuenta con aproximadamente 28 millones de bovinos, posicionándola entre las naciones con mayor inventario ganadero de América Latina. El sector representa cerca del 1,5 % del PIB nacional y genera empleo directo a más de 800.000 familias rurales.',
  },
  {
    titulo:  'Regiones que Sostienen el Hato Nacional',
    cuerpo:  'Los Llanos Orientales —Casanare, Meta, Arauca y Vichada— concentran alrededor del 30 % del inventario bovino del país. La Costa Atlántica y Antioquia completan el triángulo productivo que define la geografía ganadera de Colombia.',
  },
  {
    titulo:  'Biodiversidad y Vocación de Largo Plazo',
    cuerpo:  'La adopción creciente de sistemas silvopastoriles en el territorio nacional combina producción bovina con conservación de suelos, protección de fuentes hídricas y secuestro de carbono, consolidando un modelo ganadero compatible con la biodiversidad colombiana.',
  },
];
---

<section
  id="impacto"
  class="relative py-28 px-6 overflow-hidden"
  style="background-color: #141414; border-top: 1px solid rgba(139,26,26,0.35);"
  aria-labelledby="impacto-titulo"
>
  <!-- Resplandor dorado muy tenue centrado arriba -->
  <div
    class="absolute pointer-events-none"
    style="top: 0; left: 50%; transform: translateX(-50%); width: 700px; height: 250px;
           background: radial-gradient(ellipse at 50% 0%, rgba(201,150,58,0.05) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-6xl mx-auto">

    <!-- Separador -->
    <div class="flex items-center gap-6 mb-20" aria-hidden="true">
      <div class="flex-1 h-px" style="background: rgba(240,235,225,0.08);"></div>
      <span class="font-sans text-[9px] tracking-[0.6em] uppercase" style="color: rgba(201,150,58,0.4);">03</span>
      <div class="flex-1 h-px" style="background: rgba(240,235,225,0.08);"></div>
    </div>

    <!-- Encabezado centrado -->
    <div class="text-center mb-20" data-animate="fade-up">
      <p class="font-sans text-xs tracking-[0.35em] uppercase font-semibold mb-5" style="color: #C9963A;">
        Impacto Territorial
      </p>
      <h2 id="impacto-titulo" class="font-serif text-4xl md:text-5xl leading-[1.15] max-w-2xl mx-auto" style="color: #F0EBE1;">
        La ganadería, pilar del corazón productivo de Colombia
      </h2>
    </div>

    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Mapa — puntos luminosos dorados sobre negro -->
      <div
        class="relative flex items-center justify-center"
        data-animate="fade-up"
        aria-label="Mapa de presencia territorial en Colombia"
      >
        <div class="relative w-full max-w-sm mx-auto">
          <!-- Marco carmesí del mapa — eco del logo -->
          <div
            class="absolute pointer-events-none"
            style="inset: -12px; border: 1px solid rgba(139,26,26,0.25);"
            aria-hidden="true"
          ></div>

          <!-- SVG Colombia inline — silueta trazada a escala geográfica real -->
          <svg
            viewBox="0 0 260 350"
            class="w-full h-auto"
            xmlns="http://www.w3.org/2000/svg"
            role="img"
            aria-label="Mapa de las principales regiones ganaderas de Colombia"
          >
            <defs>
              <style>
                .dot-pulse {
                  animation: dotPulse 2.8s ease-in-out infinite;
                }
                @keyframes dotPulse {
                  0%, 100% { opacity: 1; }
                  50%       { opacity: 0.55; }
                }
                .dot-pulse-b { animation: dotPulse 2.8s ease-in-out infinite 0.7s; }
                .dot-pulse-c { animation: dotPulse 2.8s ease-in-out infinite 1.3s; }
                .dot-pulse-d { animation: dotPulse 2.8s ease-in-out infinite 2.0s; }
              </style>
              <filter id="glow-gold" x="-60%" y="-60%" width="220%" height="220%">
                <feGaussianBlur stdDeviation="4" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
              <filter id="glow-sm" x="-60%" y="-60%" width="220%" height="220%">
                <feGaussianBlur stdDeviation="2.5" result="blur"/>
                <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
              </filter>
            </defs>

            <!-- Silueta de Colombia -->
            <path
              d="M 49,98
                 L 62,82 L 82,60 L 90,48 L 102,38
                 L 118,28 L 128,18 L 140,10 L 152,20
                 L 158,36 L 154,60 L 156,88
                 L 170,108 L 192,120 L 230,132 L 240,155
                 L 238,182 L 230,210 L 220,242 L 205,278
                 L 188,308 L 165,318 L 140,312
                 L 115,305 L 92,295 L 72,278
                 L 52,260 L 20,238
                 L 34,200 L 40,172 L 38,148 L 36,122
                 Z"
              fill="rgba(139,26,26,0.07)"
              stroke="rgba(201,150,58,0.28)"
              stroke-width="1.2"
              stroke-linejoin="round"
            />

            <!-- ── Costa Caribe (Córdoba · Sucre · Bolívar) ── -->
            <circle cx="72" cy="76" r="5.5" fill="#C9963A" filter="url(#glow-gold)" class="dot-pulse"/>
            <text x="81" y="72" fill="rgba(240,235,225,0.9)" font-size="8" font-family="Poppins,sans-serif" font-weight="600" letter-spacing="0.3">Costa Caribe</text>
            <text x="81" y="82" fill="rgba(201,150,58,0.7)" font-size="6.5" font-family="Poppins,sans-serif">Córdoba · Sucre · Bolívar</text>

            <!-- ── Antioquia ── -->
            <circle cx="66" cy="134" r="5" fill="#C9963A" filter="url(#glow-gold)" class="dot-pulse-b"/>
            <text x="59" y="130" fill="rgba(240,235,225,0.9)" font-size="8" font-family="Poppins,sans-serif" font-weight="600" letter-spacing="0.3" text-anchor="end">Antioquia</text>
            <text x="59" y="140" fill="rgba(201,150,58,0.7)" font-size="6.5" font-family="Poppins,sans-serif" text-anchor="end">~2,2 M cabezas</text>

            <!-- ── Magdalena Medio ── -->
            <circle cx="106" cy="122" r="3.5" fill="rgba(240,235,225,0.5)" filter="url(#glow-sm)" class="dot-pulse-d"/>
            <text x="106" y="115" fill="rgba(240,235,225,0.62)" font-size="6.5" font-family="Poppins,sans-serif" text-anchor="middle">Magdalena Medio</text>

            <!-- ── Llanos Orientales (mayor hato nacional) ── -->
            <circle cx="148" cy="165" r="7" fill="#C9963A" filter="url(#glow-gold)" class="dot-pulse-c"/>
            <text x="159" y="161" fill="rgba(240,235,225,0.9)" font-size="8" font-family="Poppins,sans-serif" font-weight="600" letter-spacing="0.3">Llanos Orientales</text>
            <text x="159" y="171" fill="rgba(201,150,58,0.7)" font-size="6.5" font-family="Poppins,sans-serif">Casanare · Meta · Arauca</text>
          </svg>
        </div>
      </div>

      <!-- Pilares narrativos -->
      <div class="flex flex-col" data-animate="fade-up" style="transition-delay: 0.2s;">
        {pilares.map((pilar, i) => (
          <div
            class="group py-8 pl-7 transition-all duration-500"
            style={`
              border-left: 1px solid rgba(139,26,26,0.3);
              ${i < pilares.length - 1 ? 'border-bottom: 1px solid rgba(240,235,225,0.06);' : ''}
            `}
          >
            <span class="font-sans text-[10px] tracking-[0.4em] uppercase font-medium mb-3 block" style="color: rgba(201,150,58,0.6);">
              0{i + 1}
            </span>
            <h3 class="font-sans font-semibold text-base leading-snug mb-3 transition-colors duration-300 group-hover:opacity-100" style="color: rgba(240,235,225,0.8);">
              {pilar.titulo}
            </h3>
            <p class="font-body text-sm leading-relaxed transition-colors duration-300" style="color: rgba(240,235,225,0.38);">
              {pilar.cuerpo}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
